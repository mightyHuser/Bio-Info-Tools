# slidepal/.env.local.example
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-here  # openssl rand -base64 32 で生成

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

AI_GATEWAY_API_KEY=your-ai-gateway-api-key  # Vercel Dashboard → AI Gateway から取得
# 代替: vercel link → vercel env pull .env.local で VERCEL_OIDC_TOKEN を自動取得
