# slidepal/.env.local.example
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-here  # openssl rand -base64 32 で生成

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

AI_GATEWAY_API_KEY=your-ai-gateway-api-key  # Vercel Dashboard → AI Gateway から取得
# 代替: vercel link → vercel env pull .env.local で VERCEL_OIDC_TOKEN を自動取得

# ── ローカル LLM (Ollama) を使う場合 ──────────────────────────
# 1. https://ollama.com からインストール
# 2. ollama pull gemma3:4b  (ラップトップ向け / ~3GB)
#    ollama pull gemma3:27b  (高品質 / ~16GB VRAM)
# 3. 以下の設定を有効化
# AI_PROVIDER=ollama
# LOCAL_LLM_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434/api  # デフォルト値なので通常不要
